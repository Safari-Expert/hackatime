<div class="max-w-7xl mx-auto p-6 space-y-6">
  <header class="space-y-2">
    <h1 class="text-4xl font-bold text-surface-content">External Collaborators</h1>
    <p class="text-muted max-w-3xl">
      Create and manage attendance-only accounts for collaborators who do not use the developer auth flow.
    </p>
  </header>

  <section class="border border-primary rounded-xl p-6 bg-dark space-y-4">
    <div>
      <h2 class="text-2xl font-semibold text-green mb-1">Create external user</h2>
      <p class="text-sm text-muted">This creates the login and the default monitoring profile in one step.</p>
    </div>

    <% if @external_user.errors.any? %>
      <div class="rounded-lg border border-red/40 bg-red/10 px-4 py-3 text-sm text-red">
        <strong class="block font-semibold mb-1">Could not create external user</strong>
        <%= @external_user.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <%= form_with model: @external_user, scope: :external_user, url: admin_external_users_path, class: "grid gap-4 lg:grid-cols-4" do |form| %>
      <label class="grid gap-2 text-sm text-muted">
        <span>Display name</span>
        <%= form.text_field :display_name_override, required: true, class: "rounded-lg border border-surface-200 bg-surface px-3 py-2 text-surface-content" %>
      </label>

      <label class="grid gap-2 text-sm text-muted">
        <span>Username</span>
        <%= form.text_field :username, required: true, class: "rounded-lg border border-surface-200 bg-surface px-3 py-2 text-surface-content" %>
      </label>

      <label class="grid gap-2 text-sm text-muted">
        <span>Password</span>
        <%= form.password_field :password, required: true, minlength: 8, class: "rounded-lg border border-surface-200 bg-surface px-3 py-2 text-surface-content" %>
      </label>

      <label class="grid gap-2 text-sm text-muted">
        <span>Timezone</span>
        <%= form.select :timezone,
          options_for_select(TZInfo::Timezone.all_identifiers.sort, @external_user.timezone),
          {},
          class: "rounded-lg border border-surface-200 bg-surface px-3 py-2 text-surface-content" %>
      </label>

      <div class="lg:col-span-4">
        <%= form.submit "Create external user", class: "px-4 py-2 bg-primary text-on-primary font-medium rounded-lg hover:opacity-90 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </section>

  <section class="border border-primary rounded-xl p-6 bg-dark space-y-4">
    <div class="flex items-center justify-between gap-3">
      <div>
        <h2 class="text-2xl font-semibold text-surface-content">Managed accounts</h2>
        <p class="text-sm text-muted">Reset passwords, change usernames, and jump into the monitoring schedule editor.</p>
      </div>
      <span class="text-sm text-muted"><%= @external_users.size %> total</span>
    </div>

    <% if @external_users.empty? %>
      <p class="text-muted">No external collaborators created yet.</p>
    <% else %>
      <div class="space-y-4">
        <% @external_users.each do |user| %>
          <% profile = EmployeeMonitoringProfile.for_user(user) %>
          <div class="rounded-xl border border-surface-200 bg-surface p-4 space-y-4">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <div class="flex items-center gap-2">
                  <h3 class="text-xl font-semibold text-surface-content"><%= user.display_name %></h3>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-blue/20 text-blue font-medium">external</span>
                </div>
                <p class="text-sm text-muted mt-1">
                  @<%= user.username %> · <%= user.timezone %> · <%= profile.schedule_label(user: user) %>
                </p>
              </div>

              <div class="flex flex-wrap gap-2">
                <%= link_to "Edit schedule", employee_monitoring_path(user_id: user.id), class: "px-3 py-2 rounded-lg border border-primary text-primary hover:bg-primary hover:text-on-primary transition-colors text-sm font-medium" %>
                <%= button_to "Delete", admin_external_user_path(user), method: :delete, class: "px-3 py-2 rounded-lg bg-red text-on-primary hover:opacity-90 transition-colors text-sm font-medium cursor-pointer", data: { confirm: "Delete #{user.display_name}?" } %>
              </div>
            </div>

            <%= form_with model: user, scope: :external_user, url: admin_external_user_path(user), method: :patch, class: "grid gap-4 lg:grid-cols-4" do |form| %>
              <label class="grid gap-2 text-sm text-muted">
                <span>Display name</span>
                <%= form.text_field :display_name_override, required: true, class: "rounded-lg border border-surface-200 bg-dark px-3 py-2 text-surface-content" %>
              </label>

              <label class="grid gap-2 text-sm text-muted">
                <span>Username</span>
                <%= form.text_field :username, required: true, class: "rounded-lg border border-surface-200 bg-dark px-3 py-2 text-surface-content" %>
              </label>

              <label class="grid gap-2 text-sm text-muted">
                <span>New password</span>
                <%= form.password_field :password, minlength: 8, placeholder: "Leave blank to keep current password", class: "rounded-lg border border-surface-200 bg-dark px-3 py-2 text-surface-content" %>
              </label>

              <label class="grid gap-2 text-sm text-muted">
                <span>Timezone</span>
                <%= form.select :timezone,
                  options_for_select(TZInfo::Timezone.all_identifiers.sort, user.timezone),
                  {},
                  class: "rounded-lg border border-surface-200 bg-dark px-3 py-2 text-surface-content" %>
              </label>

              <div class="lg:col-span-4">
                <%= form.submit "Save changes", class: "px-4 py-2 bg-primary text-on-primary font-medium rounded-lg hover:opacity-90 transition-colors cursor-pointer" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
