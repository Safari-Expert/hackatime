# Safari Expert self-hosted Hackatime environment example.
# Copy this file to `.env` for local development or mirror the same keys in Railway service variables.

# Core Railway/runtime settings.
RAILS_ENV=production
APP_HOST=hackatime-web-development.up.railway.app
DATABASE_URL=
POOL_DATABASE_URL=
SAILORS_LOG_DATABASE_URL=
SECRET_KEY_BASE=
RAILS_MASTER_KEY=
ENCRYPTION_PRIMARY_KEY=
ENCRYPTION_DETERMINISTIC_KEY=
ENCRYPTION_KEY_DERIVATION_SALT=
SAFARI_EXPERT_SELF_HOSTED=true

# Storage. Use `local` with a Railway volume or switch to `r2` after provisioning a bucket.
ACTIVE_STORAGE_SERVICE=local
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT=

# Trusted launch from internal_ui. This must match `INTERNAL_UI_LAUNCH_SHARED_SECRET`.
HACKATIME_INTERNAL_UI_LAUNCH_SHARED_SECRET=

# Optional GitHub OAuth for direct break-glass login. Normal user access should come from internal_ui.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Bootstrap admin and initial API keys.
SAFARI_EXPERT_BOOTSTRAP_ADMIN_EMAIL=
SAFARI_EXPERT_BOOTSTRAP_ADMIN_USERNAME=
SAFARI_EXPERT_BOOTSTRAP_ADMIN_TIMEZONE=Africa/Nairobi
SAFARI_EXPERT_BOOTSTRAP_ADMIN_API_KEY_NAME=Safari Expert Internal UI
SAFARI_EXPERT_BOOTSTRAP_USER_API_KEY_NAME=Safari Expert WakaTime
SAFARI_EXPERT_BOOTSTRAP_SIGN_IN_TTL_DAYS=365

# Optional mail delivery.
SMTP_USER_NAME=
SMTP_PASSWORD=
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_FROM_EMAIL=noreply@hackatime.local

# Optional observability and analytics.
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SKYLIGHT_AUTHENTICATION=

# Optional upstream product integrations. Leave blank unless you intentionally enable them.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_USER_OAUTH_TOKEN=
SLACK_SAILORS_LOG_SIGNING_SECRET=
SLACK_SAILORS_LOG_BOT_OAUTH_TOKEN=
TELETYPE_API_KEY=
HCA_CLIENT_ID=
HCA_CLIENT_SECRET=
LOOPS_AIRTABLE_PAT=
ADDRESS_AIRTABLE_PAT=
MAIL_HACKCLUB_TOKEN=
IPINFO_API_KEY=
HACKCLUB_GEOCODER_API_KEY=
INTERNAL_API_KEYS=
HKA_REVOCATION_KEY=
